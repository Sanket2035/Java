<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Bean definition for com.pune.employee (class name is lowercase in source) -->
    <bean id="emp1" class="com.pune.employee">
        <property name="id" value="101"/>
        <property name="name" value="John Doe"/>
        <property name="address" value="123 Main St"/>
    </bean>
	
	<bean id="s1" class="com.pune.Student">
        <property name="id" value="1"/>
        <property name="name" value="Jane Smith"/>
        <property name="address" value="456 Elm St"/>
        <property name="marks">
        	<list>
        		<value>85</value>
        		<value>90</value>
        		<value>78</value>
        	</list>
        </property>
    </bean>
</beans>