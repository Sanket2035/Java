<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-background-color: #f8f9fa;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hdpack.client.controllers.DashboardController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <Label text="Dashboard Overview" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Stats Cards Row -->
    <HBox spacing="20">
        <!-- Card 1: Inventory -->
        <VBox styleClass="card" prefWidth="250">
            <Label text="Total Inventory Items" textFill="#64748b"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="12" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <!-- You can use FontAwesomeFX or an ImageView here for the icon -->
            </HBox>
        </VBox>

        <!-- Card 2: Low Stock -->
        <VBox styleClass="card" prefWidth="250">
            <Label text="Low Stock Alerts" textFill="#64748b"/>
            <Label text="1" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Card 3: Pending Jobs -->
        <VBox styleClass="card" prefWidth="250">
            <Label text="Pending Jobs" textFill="#64748b"/>
            <Label text="2" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- Alert Section -->
    <VBox styleClass="card" spacing="10">
        <Label text="⚠ Low Stock Alerts" style="-fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
        <HBox style="-fx-background-color: #fef2f2; -fx-padding: 15; -fx-background-radius: 6;" alignment="CENTER_LEFT">
            <VBox>
                <Label text="Yellow Ink Cartridge" style="-fx-font-weight: bold;"/>
                <Label text="Category: Ink" textFill="#64748b"/>
            </VBox>
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Label text="4 cartridges" textFill="#ef4444" style="-fx-font-weight: bold;"/>
                <Label text="Min: 5" textFill="#64748b"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Recent Jobs Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="Recent Jobs" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>
        <TableView fx:id="recentJobsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Job ID" prefWidth="100"/>
                <TableColumn text="Brand" prefWidth="200"/>
                <TableColumn text="Deadline" prefWidth="150"/>
                <TableColumn text="Status" prefWidth="120"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>
</VBox>