<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="20" style="-fx-background-color: #f8f9fa;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hdpack.client.controllers.InventoryController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Inventory Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Item" styleClass="btn-primary" onAction="#handleAddItem"/>
    </HBox>

    <!-- Search and Filter Bar -->
    <HBox spacing="10" styleClass="card" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search inventory..." prefWidth="350"
                   style="-fx-background-radius: 4; -fx-border-color: #e2e8f0;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Filter Buttons -->
        <Button text="All" styleClass="btn-primary"/> <!-- Active state example -->
        <Button text="Paper" styleClass="btn-secondary"/>
        <Button text="Ink" styleClass="btn-secondary"/>
        <Button text="Punch" styleClass="btn-secondary"/>
        <Button text="Paper rolls" styleClass="btn-secondary"/>
    </HBox>

    <!-- Inventory Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" text="Name" prefWidth="250"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="120"/>
                <TableColumn fx:id="colQuantity" text="Quantity" prefWidth="100"/>
                <TableColumn fx:id="colUnit" text="Unit" prefWidth="100"/>
                <TableColumn fx:id="colMinStock" text="Min Stock" prefWidth="100"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>