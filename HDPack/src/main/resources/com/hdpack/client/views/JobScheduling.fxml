<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-background-color: #f8f9fa;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hdpack.client.controllers.JobController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Job Scheduling" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Job" styleClass="btn-primary" onAction="#openAddJobModal"/>
    </HBox>

    <!-- Filter Bar -->
    <HBox spacing="10" styleClass="card" alignment="CENTER_LEFT">
        <TextField promptText="Search jobs by brand or ID..." prefWidth="300" style="-fx-background-radius: 4; -fx-border-color: #e2e8f0;"/>
        <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
        <Button text="All" styleClass="btn-primary"/>
        <Button text="Pending" styleClass="btn-secondary"/>
        <Button text="In Progress" styleClass="btn-secondary"/>
        <Button text="Completed" styleClass="btn-secondary"/>
    </HBox>

    <!-- Cards Container -->
    <FlowPane hgap="20" vgap="20">

        <!-- Job Card Example 1 -->
        <VBox styleClass="card" prefWidth="400" spacing="10">
            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Nike Sports" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                    <Label text="Job ID: JOB-001" textFill="#64748b"/>
                </VBox>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                <Label text=" In-progress " styleClass="status-pill-blue"/>
            </HBox>

            <HBox spacing="20"><Label text="Quantity:" prefWidth="80" textFill="#64748b"/><Label text="5,000 stickers"/></HBox>
            <HBox spacing="20"><Label text="Start Date:" prefWidth="80" textFill="#64748b"/><Label text="2025-11-20"/></HBox>
            <HBox spacing="20"><Label text="Deadline:" prefWidth="80" textFill="#64748b"/><Label text="2025-11-30"/></HBox>

            <Label text="Custom die-cut logo stickers, glossy finish"
                   style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 4;" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Edit" styleClass="btn-secondary" prefWidth="100"/>
                <Button text="Delete" styleClass="btn-danger-outline" prefWidth="100"/>
            </HBox>
        </VBox>

        <!-- You can add more cards programmatically in the controller -->

    </FlowPane>
</VBox>